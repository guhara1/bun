{
  "name": "bun-massage",
  "version": "1.0.0",
  "private": true,
  "description": "Bun 마사지 — 서울·경기·인천 출장마사지 수도권 질문형 가이드 (정적 사이트)",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "serve": "node --experimental-default-type=module -e \"import('node:http').then(({default:h})=>import('node:fs').then(({default:fs})=>h.createServer((q,s)=>{let p=decodeURIComponent(q.url.split('?')[0]);if(p.endsWith('/'))p+='index.html';let f='dist'+p;try{const t=p.endsWith('.css')?'text/css':p.endsWith('.svg')?'image/svg+xml':p.endsWith('.xml')?'application/xml':'text/html';s.writeHead(200,{'content-type':t+';charset=utf-8'});s.end(fs.readFileSync(f));}catch(e){s.writeHead(404);s.end(fs.readFileSync('dist/404.html'));}}).listen(8080,()=>console.log('http://localhost:8080'))))\""
  },
  "engines": {
    "node": ">=18"
  }
}
